(load "Test.carp")
(use Test)
(load "geometry.carp")
(use Geometry)

(deftest geometry-test
  (let [process-test-state (ref (Test.State.init 0 0))
        
        ;; Sphere-Sphere
        s1 (Sphere.init (Vector3.init 0.0 0.0 0.0) 1.0)
        s2 (Sphere.init (Vector3.init 1.5 0.0 0.0) 1.0)
        s3 (Sphere.init (Vector3.init 2.5 0.0 0.0) 1.0)
        
        t1 (assert-true process-test-state (Sphere.intersect? &s1 &s2) "Sphere-Sphere intersect")
        t2 (assert-true &t1 (not (Sphere.intersect? &s1 &s3)) "Sphere-Sphere non-intersect")

        ;; AABB-AABB
        a1 (AABB.init (Vector3.init 0.0 0.0 0.0) (Vector3.init 1.0 1.0 1.0))
        a2 (AABB.init (Vector3.init 0.5 0.5 0.5) (Vector3.init 1.5 1.5 1.5))
        a3 (AABB.init (Vector3.init 1.5 1.5 1.5) (Vector3.init 2.5 2.5 2.5))

        t3 (assert-true &t2 (AABB.intersect? &a1 &a2) "AABB-AABB intersect")
        t4 (assert-true &t3 (not (AABB.intersect? &a1 &a3)) "AABB-AABB non-intersect")

        ;; Ray-Sphere
        r1 (Ray.init (Vector3.init -5.0 0.0 0.0) (Vector3.init 1.0 0.0 0.0))
        r2 (Ray.init (Vector3.init -5.0 2.0 0.0) (Vector3.init 1.0 0.0 0.0))

        t5 (assert-true &t4 (Ray.intersect-sphere? &r1 &s1) "Ray-Sphere intersect")
        t6 (assert-true &t5 (not (Ray.intersect-sphere? &r2 &s1)) "Ray-Sphere non-intersect")

        ;; Ray-AABB
        t7 (assert-true &t6 (Ray.intersect-aabb? &r1 &a1) "Ray-AABB intersect")
        t8 (assert-true &t7 (not (Ray.intersect-aabb? &r2 &a1)) "Ray-AABB non-intersect")

        ;; Sphere-AABB
        t9 (assert-true &t8 (Sphere.intersect-aabb? &s1 &a1) "Sphere-AABB intersect")
        t10 (assert-true &t9 (not (Sphere.intersect-aabb? &s3 &a1)) "Sphere-AABB non-intersect")
        ]
    t10))
